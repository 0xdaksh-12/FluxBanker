# Server
SERVER_PORT=8080
NODE_ENV=development

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fluxbanker
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Security / JWT
JWT_SECRET_ACCESS=your_access_token_secret_here_make_it_very_long_and_secure
JWT_SECRET_REFRESH=your_refresh_token_secret_here_make_it_very_long_and_secure
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Client
CLIENT_URL=http://localhost:5173
